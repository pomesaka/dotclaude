{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(jj status:*)",
      "Bash(gh pr view:*)",
      "Bash(fd:*)",
      "Bash(jj diff:*)",
      "Bash(jj bookmark list)",
      "Bash(jj log:*)",
      "Bash(jj diffu:*)",
      "Bash(jj desc:*)",
      "Bash(ls:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr create:*)",
      "Bash(bun run:*)",
      "Bash(task:*)",
      "Read(**/.env.example)",
      "Read(**/.env.template)",
      "Read(/Users/pomesaka/.claude/**)",
      "Bash(cat ~/.claude/:*)",
      "Bash(cat:*)",
      "Bash(sed:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(awk:*)",
      "Bash(playwright-cli:*)",
      "Bash(gh project:*)",
      "Bash(bun run:*)",
      "Bash(python3 *)",
      "Bash(bash ~/.claude/skills/check-best-practices/fetch.sh)",
      "Bash(bash ~/.claude/skills/check-best-practices/env.sh)"
    ],
    "deny": [
      "Read(**/.env)"
    ],
    "additionalDirectories": [
      "/Users/pomesaka/.claude",
      "/Users/pomesaka/github.com/pomesaka/dotclaude"
    ]
  },
  "model": "opusplan",
  "statusLine": {
    "type": "command",
    "command": "/Users/pomesaka/.local/share/claude-deck/statusline.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "claude-deck@claude-deck": true
  },
  "extraKnownMarketplaces": {
    "claude-deck": {
      "source": {
        "source": "github",
        "repo": "pomesaka/claude-deck"
      }
    }
  },
  "effortLevel": "high",
  "teammateMode": "in-process",
  "feedbackSurveyState": {
    "lastShownTime": 1754021250248
  },
  "skipAutoPermissionPrompt": true
}
