{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(jj status:*)",
      "Bash(gh pr view:*)",
      "Bash(fd:*)",
      "Bash(jj diff:*)",
      "Bash(jj bookmark list)",
      "Bash(jj log:*)",
      "Bash(jj diffu:*)",
      "Bash(jj desc:*)",
      "Bash(ls:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr create:*)",
      "Bash(bun run:*)",
      "Bash(task:*)",
      "Read(**/.env.example)",
      "Read(**/.env.template)"
    ],
    "deny": [
      "Read(**/.env)"
    ]
  },
  "statusLine": {
    "type": "none"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "claude-deck@claude-deck": true
  },
  "extraKnownMarketplaces": {
    "claude-deck": {
      "source": {
        "source": "github",
        "repo": "pomesaka/claude-deck"
      }
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754021250248
  }
}
